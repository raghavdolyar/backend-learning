<div class="bg-[#161618] border border-white/8 rounded-xl overflow-hidden w-75 transition-all group">

  <div class="relative">
    <img src="<%= home.photoUrl %>" alt="<%= home.name %>" class="w-full h-44 object-cover" />

    <button onclick="this.classList.toggle('favourited')" class="absolute top-2.5 right-2.5 p-1.5 rounded-full bg-black/50 hover:bg-black/70 text-gray-400 hover:text-[#e51414] backdrop-blur-sm transition-colors [&.favourited]:text-[#e51414]" title="Favourite">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path class="heart-path" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
      </svg>
    </button>

    <style>
      .favourited svg path {
        fill: #e51414;
      }
    </style>
  </div>

  <div class="p-4 flex flex-col gap-3">

    <div class="flex items-start justify-between gap-2">
      <h3 class="text-white text-[17px] font-semibold leading-snug">
        <%= home.name %>
      </h3>
      <span class="flex items-center gap-0.5 text-[13px] text-yellow-400 shrink-0 mt-0.5">
        ★ <%= home.rating %>
      </span>
    </div>

    <div class="flex items-center gap-1.5 text-gray-500 text-[12px]">
      <svg class="w-3.5 h-3.5 text-[#e51414] shrink-0" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" />
      </svg>
      <%= home.location %>
    </div>

    <div class="border-t border-white/6 pt-3 flex items-center justify-between gap-2">
      <span class="text-white text-sm font-medium">
        ₹<%= home.price %> <span class="text-gray-500 text-xs font-normal">/ night</span>
      </span>
      <div class="flex items-center gap-1.5">
        <a href="#" class="px-3 py-1.5 border border-white/10 hover:border-white/20 hover:bg-white/5 text-gray-400 text-xs font-medium rounded-lg transition-colors">
          View
        </a>
        <a href="#" class="px-3 py-1.5 bg-[#e51414] hover:bg-[#c10d0d] text-white text-xs font-medium rounded-lg transition-colors">
          Book
        </a>
      </div>
    </div>

  </div>
</div>