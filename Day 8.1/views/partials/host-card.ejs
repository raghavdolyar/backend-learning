<div class="bg-[#1c1c21] border border-white/10 rounded-xl overflow-hidden w-75 transition-colors group">

  <div class="relative">
    <img src="<%= home.photoUrl %>" alt="<%= home.name %>" class="w-full h-44 object-cover brightness-90" />

    <div class="absolute top-2.5 right-2.5 flex gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
      <button class="p-1.5 rounded-lg bg-black/60 hover:bg-white/20 text-white backdrop-blur-sm transition-colors" title="Edit">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
        </svg>
      </button>
      <button class="p-1.5 rounded-lg bg-black/60 hover:bg-[#e51414]/80 text-white backdrop-blur-sm transition-colors" title="Delete">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6" />
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
          <path d="M10 11v6M14 11v6" />
          <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
        </svg>
      </button>
    </div>

    <span class="absolute bottom-2.5 left-3 text-[10px] font-semibold tracking-wide uppercase bg-black/60 text-gray-300 backdrop-blur-sm px-2 py-0.5 rounded-full">
      Your listing
    </span>
  </div>

  <div class="p-4 flex flex-col gap-3">

    <div class="flex items-start justify-between gap-2">
      <h3 class="text-white text-[17px] font-semibold leading-snug">
        <%= home.name %>
      </h3>
      <span class="flex items-center gap-1 text-[13px] text-yellow-400 shrink-0 mt-0.5">
        ★ <%= home.rating %>
      </span>
    </div>

    <div class="flex items-center gap-1.5 text-gray-500 text-[12px]">
      <svg class="w-3.5 h-3.5 text-[#e51414] shrink-0" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" />
      </svg>
      <%= home.location %>
    </div>

    <div class="border-t border-white/5 pt-3 flex items-center justify-between">
      <span class="text-white text-sm font-medium">
        ₹<%= home.price %> <span class="text-gray-500 text-xs font-normal">/ night</span>
      </span>
      <span class="text-[11px] text-gray-600 italic">Hover to manage</span>
    </div>

  </div>
</div>