<%- include('../partials/head') %>

<header class="mb-8 text-center">
  <h2 class="text-3xl font-semibold text-white tracking-tight">
    Register your <span class="text-[#e51414]">Home</span>
  </h2>
</header>

<main>
  <form action="/host/add-home" method="POST" class="flex flex-col gap-4 w-80" autocomplete="off">

    <div class="flex flex-col gap-1.5">
      <label for="housename" class="text-sm text-gray-400">House Name</label>
      <input type="text" name="housename" id="housename" required class="bg-[#1c1c21] border border-white/10 text-white text-sm rounded-lg px-4 py-2.5 outline-none focus:border-[#e51414] transition-colors placeholder-gray-600" placeholder="e.g. Cozy Mountain Cabin" />
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="location" class="text-sm text-gray-400">Location</label>
      <input type="text" name="location" id="location" required class="bg-[#1c1c21] border border-white/10 text-white text-sm rounded-lg px-4 py-2.5 outline-none focus:border-[#e51414] transition-colors placeholder-gray-600" placeholder="e.g. Manali, Himachal Pradesh" />
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="price" class="text-sm text-gray-400">Price per Night (₹)</label>
      <input type="number" name="price" id="price" min="0" required class="bg-[#1c1c21] border border-white/10 text-white text-sm rounded-lg px-4 py-2.5 outline-none focus:border-[#e51414] transition-colors placeholder-gray-600" placeholder="e.g. 2500" />
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="rating" class="text-sm text-gray-400">Rating (1 – 5)</label>
      <input type="number" name="rating" id="rating" min="1" max="5" step="0.1" required class="bg-[#1c1c21] border border-white/10 text-white text-sm rounded-lg px-4 py-2.5 outline-none focus:border-[#e51414] transition-colors placeholder-gray-600" placeholder="e.g. 4.5" />
    </div>

    <div class="flex flex-col gap-1.5">
      <label for="photoUrl" class="text-sm text-gray-400">Photo URL</label>
      <input type="url" name="photoUrl" id="photoUrl" class="bg-[#1c1c21] border border-white/10 text-white text-sm rounded-lg px-4 py-2.5 outline-none focus:border-[#e51414] transition-colors placeholder-gray-600" placeholder="https://example.com/photo.jpg" />
    </div>

    <button type="submit" class="mt-2 px-5 py-2.5 bg-[#e51414] hover:bg-[#c10d0d] text-white text-sm font-medium rounded-lg transition-colors">
      Submit
    </button>

  </form>
</main>

</div>
</body>

</html>